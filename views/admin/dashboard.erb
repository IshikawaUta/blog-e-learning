<div class="py-12">
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 border-b border-white border-opacity-30 pb-10">
        <div>
            <h1 class="text-4xl font-extrabold text-blue-900 mb-2 tracking-tight">Admin Dashboard</h1>
            <p class="text-slate-500">Kelola semua konten e-learning Anda dari sini.</p>
        </div>
        <div class="flex flex-wrap gap-4 mt-4 md:mt-0">
            <a href="/" class="px-6 py-4 rounded-2xl glass text-blue-600 font-bold text-base hover:bg-white transition flex items-center">
                Lihat Web
            </a>
            <a href="/admin/comments" class="px-6 py-4 rounded-2xl glass text-amber-600 font-bold text-base hover:bg-white transition flex items-center relative">
                Komentar
            </a>
            <a href="/admin/categories" class="px-6 py-4 rounded-2xl glass text-indigo-600 font-bold text-base hover:bg-white transition flex items-center">
                Kategori
            </a>
            <a href="/admin/settings" class="px-6 py-4 rounded-2xl glass text-slate-600 font-bold text-base hover:bg-white transition flex items-center">
                Pengaturan
            </a>
            <a href="/admin/posts/new" class="px-6 py-4 rounded-2xl bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold text-base hover:shadow-lg hover:scale-[1.05] transform transition active:scale-95 flex items-center">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Post Baru
            </a>
        </div>
    </header>

    <form action="/admin/dashboard" method="GET" class="flex gap-4 mb-8">
        <div class="relative flex-grow">
            <input type="text" name="q" value="<%= @search_query %>" placeholder="Cari post di dashboard..." 
                class="w-full px-6 py-4 rounded-2xl glass bg-white focus:bg-white border-none focus:ring-4 focus:ring-blue-100 transition outline-none shadow-md">
            <button type="submit" class="absolute right-2 top-2 bottom-2 px-5 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 transition">
                Cari
            </button>
        </div>
        <% if @search_query && !@search_query.empty? %>
            <a href="/reset-search?admin=true" class="px-6 py-4 rounded-2xl glass text-slate-500 font-bold hover:text-red-500 transition flex items-center">
                Reset
            </a>
        <% end %>
    </form>

    <% if @search_query && !@search_query.empty? %>
        <div class="mb-6 px-4">
            <p class="text-lg text-slate-600 font-medium">
                Ditemukan <span class="text-blue-600 font-bold"><%= @total_posts %></span> postingan untuk pencarian "<span class="text-blue-600 font-bold"><%= @search_query %></span>"
            </p>
        </div>
    <% end %>

    <div class="glass rounded-[2rem] overflow-hidden shadow-xl border border-white border-opacity-30">
        <table class="w-full text-left">
            <thead class="bg-blue-600 bg-opacity-5 border-b border-white border-opacity-50">
                <tr>
                    <th class="px-8 py-6 text-sm font-bold text-blue-900 uppercase tracking-widest">Judul Post</th>
                    <th class="px-8 py-6 text-sm font-bold text-blue-900 uppercase tracking-widest">Tanggal Dibuat</th>
                    <th class="px-8 py-6 text-sm font-bold text-blue-900 uppercase tracking-widest text-right">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white divide-opacity-30">
                <% if @posts.any? %>
                    <% @posts.each do |post| %>
                        <tr class="hover:bg-white hover:bg-opacity-40 transition">
                            <td class="px-8 py-8">
                                <span class="text-lg font-bold text-slate-800 leading-tight block">
                                    <%= post.title %>
                                </span>
                            </td>
                            <td class="px-8 py-8 text-slate-500 font-medium">
                                <%= post.created_at.strftime("%d %b %Y, %H:%M") if post.created_at %>
                            </td>
                            <td class="px-8 py-8 text-right space-x-4">
                                <a href="/admin/posts/<%= post.id %>/edit" class="inline-flex items-center px-4 py-2 rounded-xl btn-glass font-bold text-blue-600 text-sm">
                                    Edit
                                </a>
                                <form action="/admin/posts/<%= post.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Apakah Anda yakin ingin menghapus post ini?')">
                                    <%= csrf_tag %>
                                    <button type="submit" class="px-4 py-2 rounded-xl bg-red-100 bg-opacity-60 border border-red-200 text-red-600 font-bold text-sm hover:bg-red-200 hover:text-red-700 transition">
                                        Hapus
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% end %>
                <% else %>
                    <tr>
                        <td colspan="3" class="px-8 py-20 text-center text-slate-400 italic">
                            Belum ada post. Mulailah dengan membuat yang baru!
                        </td>
                    </tr>
                <% end %>
            </tbody>
        </table>
    </div>

    <% if @total_pages > 1 %>
        <div class="mt-8 flex justify-between items-center px-4">
            <div class="text-slate-500 text-sm font-medium">
                Menampilkan halaman <strong><%= @current_page %></strong> dari <strong><%= @total_pages %></strong>
            </div>
            
            <div class="flex gap-2">
                <% if @current_page > 1 %>
                    <a href="/admin/dashboard?page=<%= @current_page - 1 %><%= "&q=#{@search_query}" if @search_query && !@search_query.empty? %>" 
                       class="px-4 py-2 rounded-xl glass text-blue-600 font-bold hover:bg-white transition">
                       Prev
                    </a>
                <% end %>
                
                <% if @current_page < @total_pages %>
                    <a href="/admin/dashboard?page=<%= @current_page + 1 %><%= "&q=#{@search_query}" if @search_query && !@search_query.empty? %>" 
                       class="px-4 py-2 rounded-xl glass text-blue-600 font-bold hover:bg-white transition">
                       Next
                    </a>
                <% end %>
            </div>
        </div>
    <% end %>
</div>
