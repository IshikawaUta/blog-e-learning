<div class="max-w-2xl mx-auto py-12">
    <div class="glass p-12 rounded-[2.5rem] shadow-xl">
        <header class="mb-10 text-center">
            <h1 class="text-3xl font-black text-slate-900 mb-2">Pengaturan Akun</h1>
            <p class="text-slate-500">Perbarui profil administrator dan kata sandi Anda secara berkala.</p>
        </header>

        <form action="/admin/settings" method="POST" class="space-y-8">
            <%= csrf_tag %>
            
            <div class="space-y-6">
                <!-- Username Section -->
                <div>
                    <label for="username" class="block text-sm font-bold text-slate-700 mb-2 ml-1">Username Admin</label>
                    <input type="text" name="username" id="username" required value="<%= @user.username %>"
                        class="w-full px-5 py-4 rounded-2xl bg-white bg-opacity-50 border border-slate-200 focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-100 transition duration-200 outline-none font-medium">
                </div>

                <div class="pt-4 border-t border-white border-opacity-30">
                    <p class="text-xs font-black text-blue-500 uppercase tracking-widest mb-6">Ubah Kata Sandi (Opsional)</p>
                    
                    <div class="space-y-6">
                        <div>
                            <label for="password" class="block text-sm font-bold text-slate-700 mb-2 ml-1">Password Baru</label>
                            <input type="password" name="password" id="password" placeholder="Kosongkan jika tidak ingin mengubah..."
                                class="w-full px-5 py-4 rounded-2xl bg-white bg-opacity-50 border border-slate-200 focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-100 transition duration-200 outline-none font-medium">
                        </div>
                        
                        <div>
                            <label for="password_confirmation" class="block text-sm font-bold text-slate-700 mb-2 ml-1">Konfirmasi Password Baru</label>
                            <input type="password" name="password_confirmation" id="password_confirmation" placeholder="Ulangi password baru..."
                                class="w-full px-5 py-4 rounded-2xl bg-white bg-opacity-50 border border-slate-200 focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-100 transition duration-200 outline-none font-medium">
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex gap-4 pt-4">
                <button type="submit" 
                    class="flex-grow py-5 rounded-[2rem] bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-black text-xl hover:shadow-2xl hover:scale-[1.03] transform transition active:scale-95 shadow-lg">
                    Simpan Perubahan
                </button>
                <a href="/admin/dashboard" 
                    class="px-8 py-5 rounded-[2rem] bg-slate-100 bg-opacity-60 text-slate-600 font-bold text-lg hover:bg-slate-200 transition text-center flex items-center">
                    Batal
                </a>
            </div>
        </form>
    </div>
</div>
