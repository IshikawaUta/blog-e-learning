<div class="py-12">
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 border-b border-white border-opacity-30 pb-10">
        <div>
            <h1 class="text-4xl font-extrabold text-blue-900 mb-2 tracking-tight">Manajemen Kategori</h1>
            <p class="text-slate-500">Kelola kategori untuk mengelompokkan materi e-learning Anda.</p>
        </div>
        <div class="flex gap-4 mt-4 md:mt-0">
            <a href="/admin/dashboard" class="px-8 py-4 rounded-2xl glass text-slate-600 font-bold text-lg hover:bg-white transition flex items-center">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Dashboard
            </a>
        </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Add Category Form -->
        <div class="lg:col-span-1">
            <div class="glass p-8 rounded-[2.5rem] shadow-xl sticky top-8">
                <h2 class="text-2xl font-bold text-blue-900 mb-6">Tambah Kategori</h2>
                <form action="/admin/categories" method="POST" class="space-y-6">
                    <%= csrf_tag %>
                    <div>
                        <label for="name" class="block text-sm font-bold text-slate-700 mb-3 px-1 uppercase tracking-wider">Nama Kategori</label>
                        <input type="text" name="name" id="name" required placeholder="Contoh: Pemrograman"
                            class="w-full px-6 py-4 rounded-[2rem] bg-white bg-opacity-50 border border-slate-200 focus:border-blue-500 focus:bg-white focus:ring-8 focus:ring-blue-50 transition duration-300 outline-none text-lg">
                    </div>
                    <button type="submit" class="w-full py-4 rounded-[2rem] bg-blue-600 text-white font-bold text-lg hover:bg-blue-700 hover:shadow-lg transition shadow-md">
                        Simpan Kategori
                    </button>
                </form>
            </div>
        </div>

        <!-- Categories List -->
        <div class="lg:col-span-2">
            <div class="glass rounded-[2.5rem] overflow-hidden shadow-xl border border-white border-opacity-30">
                <table class="w-full text-left">
                    <thead class="bg-blue-600 bg-opacity-5 border-b border-white border-opacity-50">
                        <tr>
                            <th class="px-8 py-6 text-sm font-bold text-blue-900 uppercase tracking-widest">ID</th>
                            <th class="px-8 py-6 text-sm font-bold text-blue-900 uppercase tracking-widest">Nama Kategori</th>
                            <th class="px-8 py-6 text-sm font-bold text-blue-900 uppercase tracking-widest text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white divide-opacity-30">
                        <% if @categories && @categories.any? %>
                            <% @categories.each do |category| %>
                                <tr class="hover:bg-white hover:bg-opacity-40 transition group">
                                    <td class="px-8 py-6 text-slate-400 font-mono text-sm">#<%= category.id %></td>
                                    <td class="px-8 py-6">
                                        <form id="edit-form-<%= category.id %>" action="/admin/categories/<%= category.id %>" method="POST" class="flex gap-2">
                                            <%= csrf_tag %>
                                            <input type="text" name="name" value="<%= category.name %>" 
                                                class="bg-transparent border-none focus:ring-0 font-bold text-slate-800 text-lg p-0 w-full focus:text-blue-600 transition"
                                                onblur="document.getElementById('edit-form-<%= category.id %>').submit()">
                                        </form>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <form action="/admin/categories/<%= category.id %>/delete" method="POST" onsubmit="return confirm('Hapus kategori ini? Blog post yang menggunakan kategori ini akan menjadi Uncategorized.')" class="inline">
                                            <%= csrf_tag %>
                                            <button type="submit" class="p-3 rounded-xl bg-red-50 text-red-500 hover:bg-red-500 hover:text-white transition shadow-sm border border-red-100">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% end %>
                        <% else %>
                            <tr>
                                <td colspan="3" class="px-8 py-20 text-center text-slate-400 italic">
                                    Belum ada kategori. Tambahkan melalui form di samping.
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
            <p class="mt-6 text-sm text-slate-400 px-8 italic">
                Tips: Klik pada nama kategori untuk mengedit secara langsung. Tekan enter atau klik di luar untuk menyimpan.
            </p>
        </div>
    </div>
</div>
